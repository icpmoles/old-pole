{{- $image := .Page.Resources.GetMatch .Destination -}}

{{- $used:= $image}}

{{- $webpsrc := "" -}}
{{- $webpsrcfit := "" -}}
{{- $jpgsrc := "" -}}
{{- $webpsrc2 := "" -}}
{{- $jpgsrc2 := "" -}}
{{- $webpsrc720 := "" -}}
{{- $usedsrc:= "" -}}
{{- $animated := false -}}
{{- if ne $image.MediaType.SubType  "gif"  -}}
    {{- $jpgsrc = ($image.Resize "720x jpg" ) -}}
    {{- $jpgsrc2 = ($image.Resize "1440x jpg" )  -}}
    {{- $usedsrc = $jpgsrc.Permalink }}
{{- else -}}
    {{- $usedsrc = $image.Permalink   -}}
    {{- $animated = true  -}}
{{- end -}}
<img 
    src="{{- $usedsrc -}}" 
    {{- with .Text}}  alt="{{-  plainify  . | safeHTML}}" {{- end -}}   
    loading="lazy"
    width="{{$used.Width}}" 
    height="{{$used.Height}}"
    />
[{{- with .Title}}{{.}}{{ end -}}]